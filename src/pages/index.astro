---
import Layout from '../layouts/Layout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import PortfolioGrid from '../components/PortfolioGrid.astro';
import { services, additionalServices } from '../data/services';
import { portfolioItems, categories } from '../data/portfolio';

// Pick a mix of before/after pairs and cover shots for the homepage
const featuredPortfolio = portfolioItems.filter(p =>
  p.imageLabel && (p.imageLabel.includes('After') || p.imageLabel.includes('Cover') || p.imageLabel.includes('Render') || p.imageLabel.includes('Completed'))
).slice(0, 12);
---

<Layout title="Home" description="REMODzz — Premier remodeling and new home construction serving Northern Illinois & Southern Wisconsin. Kitchens, bathrooms, basements, additions, decks, new homes, handyman.">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg">
      <div class="hero-overlay"></div>
    </div>
    <div class="container hero-content">
      <div class="hero-text">
        <img src="/images/remodzz-logo-full.png" alt="REMODzz" class="hero-logo animate-fade-up" />
        <span class="badge animate-fade-up delay-1">Northern Illinois & Southern Wisconsin</span>
        <h1 class="animate-fade-up delay-2">You Know You<br><span class="text-primary">Want To</span></h1>
        <p class="animate-fade-up delay-3">Transform your home with the region's most trusted construction experts. From kitchen remodels to complete new home construction — on schedule and on budget.</p>
        <div class="hero-actions animate-fade-up delay-3">
          <a href="/contact" class="btn btn-primary btn-lg">Schedule a Consult</a>
          <a href="/portfolio" class="btn btn-outline btn-lg">View Our Work</a>
        </div>
        <div class="hero-stats animate-fade-up delay-4">
          <div class="stat">
            <strong>20+</strong>
            <span>Years Experience</span>
          </div>
          <div class="stat">
            <strong>500+</strong>
            <span>Projects Completed</span>
          </div>
          <div class="stat">
            <strong>2 yr</strong>
            <span>Warranty Coverage</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES OVERVIEW -->
  <section class="section bg-darker" id="services">
    <div class="container">
      <div class="section-header" data-animate>
        <span class="section-label">What We Do</span>
        <h2 class="section-title">Expert Services</h2>
        <p class="section-desc">From simple repairs to complete home transformations, we have the experience and skill to make your project a success.</p>
      </div>
      <div class="grid grid-4">
        {services.map(s => (
          <ServiceCard
            title={s.shortTitle}
            icon={s.icon}
            description={s.description}
            href={`/services/${s.slug}`}
          />
        ))}
      </div>
      <div class="grid grid-3" style="margin-top: 24px;">
        {additionalServices.map(s => (
          <ServiceCard
            title={s.title}
            icon={s.icon}
            description={s.description}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- WHY CHOOSE US HIGHLIGHT -->
  <section class="section bg-dark" id="why-us">
    <div class="container">
      <div class="why-grid">
        <div class="why-text" data-animate>
          <span class="section-label">The REMODzz Difference</span>
          <h2 class="section-title">Five Reasons We Stand Apart</h2>
          <p>95% of contractors don't offer our level of transparency and commitment. Here's what makes us different.</p>
          <div class="advantages-list">
            <div class="advantage">
              <div class="advantage-num">1</div>
              <div>
                <h4>Detailed Proposals</h4>
                <p>54+ project categories examined. No surprises, no hidden costs.</p>
              </div>
            </div>
            <div class="advantage">
              <div class="advantage-num">2</div>
              <div>
                <h4>In-House Design</h4>
                <p>Professional renderings and layouts before construction begins.</p>
              </div>
            </div>
            <div class="advantage">
              <div class="advantage-num">3</div>
              <div>
                <h4>Guaranteed Schedules</h4>
                <p>Calendar of events with penalties if we miss our dates.</p>
              </div>
            </div>
            <div class="advantage">
              <div class="advantage-num">4</div>
              <div>
                <h4>Custom Cabinetry</h4>
                <p>Unlimited options at competitive pricing. Creative storage is our specialty.</p>
              </div>
            </div>
            <div class="advantage">
              <div class="advantage-num">5</div>
              <div>
                <h4>Two-Year Warranty</h4>
                <p>Industry-leading protection across all project types.</p>
              </div>
            </div>
          </div>
          <a href="/about#advantages" class="btn btn-outline" style="margin-top: 24px;">Learn More</a>
        </div>
        <div class="why-image" data-animate>
          <img src="/images/portfolio/deck-greenoaks-after.jpg" alt="Quality craftsmanship by REMODzz" loading="lazy">
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURED PORTFOLIO -->
  <section class="section bg-darker">
    <div class="container">
      <div class="section-header" data-animate>
        <span class="section-label">Our Work</span>
        <h2 class="section-title">Featured Projects</h2>
        <p class="section-desc">Browse a selection from our portfolio of completed projects across Northern Illinois and Southern Wisconsin.</p>
      </div>
      <PortfolioGrid items={featuredPortfolio} showFilters={false} />
      <div class="text-center" style="margin-top: 40px;" data-animate>
        <a href="/portfolio" class="btn btn-outline">View Full Portfolio</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-card" data-animate>
        <div class="cta-content">
          <h2>Ready to Transform Your Space?</h2>
          <p>Schedule your free, no-hassle consultation today. We'll discuss your vision, timeline, and budget — and show you why hundreds of homeowners trust REMODzz.</p>
        </div>
        <div class="cta-actions">
          <a href="/contact" class="btn btn-primary btn-lg">Get Free Estimate</a>
          <a href="tel:8476037614" class="btn btn-ghost btn-lg">📞 847.603.7614</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* Hero */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background: url('/images/hero-bg.jpg') center/cover no-repeat;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(10,10,10,0.92) 0%, rgba(10,10,10,0.65) 50%, rgba(10,10,10,0.4) 100%);
  }
  .hero-content {
    position: relative;
    z-index: 2;
    padding-top: var(--nav-height);
  }
  .hero-text {
    max-width: 680px;
  }
  .hero-logo {
    width: clamp(280px, 45vw, 480px);
    height: auto;
    margin-bottom: 24px;
    filter: drop-shadow(0 2px 20px rgba(0,0,0,0.6));
  }
  .hero h1 {
    font-size: clamp(2.8rem, 6vw, 4.5rem);
    font-weight: 800;
    line-height: 1.05;
    margin: 20px 0 24px;
  }
  .hero p {
    font-size: 1.2rem;
    color: var(--text);
    line-height: 1.7;
    margin-bottom: 32px;
  }
  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
  .hero-stats {
    display: flex;
    gap: 48px;
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .stat strong {
    display: block;
    font-family: var(--font-heading);
    font-size: 2rem;
    color: var(--primary);
  }
  .stat span {
    font-size: 0.85rem;
    color: var(--text-light);
  }

  /* Why Choose Us */
  .why-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 60px;
    align-items: start;
  }
  .why-text > p {
    color: var(--text);
    margin-bottom: 32px;
    font-size: 1.05rem;
  }
  .advantages-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .advantage {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }
  .advantage-num {
    flex-shrink: 0;
    width: 42px;
    height: 42px;
    background: var(--primary);
    color: var(--darkest);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-family: var(--font-heading);
    font-size: 1rem;
  }
  .advantage h4 {
    font-size: 1.05rem;
    margin-bottom: 4px;
  }
  .advantage p {
    font-size: 0.9rem;
    color: var(--text-light);
    margin: 0;
  }
  .why-image img {
    width: 100%;
    border-radius: var(--radius-xl);
    object-fit: cover;
    max-height: 600px;
  }

  /* CTA */
  .cta-section {
    padding: 80px 0;
    background: var(--dark);
  }
  .cta-card {
    background: linear-gradient(135deg, rgba(212,160,60,0.1), rgba(212,160,60,0.03));
    border: 1px solid var(--primary-border);
    border-radius: var(--radius-xl);
    padding: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
  }
  .cta-content h2 {
    font-size: 2rem;
    margin-bottom: 12px;
  }
  .cta-content p {
    color: var(--text);
    font-size: 1.05rem;
    max-width: 520px;
  }
  .cta-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex-shrink: 0;
  }

  @media (max-width: 900px) {
    .why-grid { grid-template-columns: 1fr; }
    .why-image { order: -1; }
    .cta-card { flex-direction: column; text-align: center; padding: 40px; }
    .cta-actions { flex-direction: row; }
    .hero-stats { gap: 24px; }
  }
  @media (max-width: 640px) {
    .hero-stats { flex-wrap: wrap; gap: 20px; }
    .stat strong { font-size: 1.5rem; }
    .cta-actions { flex-direction: column; width: 100%; }
  }
</style>
