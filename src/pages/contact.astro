---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Contact REMODzz for a free, no-hassle estimate on your remodeling or construction project. Serving Northern Illinois and Southern Wisconsin.">

  <section class="page-hero">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a> <span>/</span> <span>Contact</span>
      </div>
      <h1>Get In <span class="text-primary">Touch</span></h1>
      <p>Ready to transform your space? Contact us for a free, no-hassle estimate.</p>
    </div>
  </section>

  <section class="section bg-darker">
    <div class="container">
      <div class="contact-grid">
        <!-- Info -->
        <div class="contact-info" data-animate>
          <div class="info-card card">
            <div class="info-item">
              <div class="info-icon">📞</div>
              <div>
                <h4>Phone</h4>
                <a href="tel:8476037614" class="info-value">847.603.7614</a>
              </div>
            </div>
            <div class="info-item">
              <div class="info-icon">📠</div>
              <div>
                <h4>Fax</h4>
                <p class="info-value">847.481.8829</p>
              </div>
            </div>
            <div class="info-item">
              <div class="info-icon">📍</div>
              <div>
                <h4>Service Area</h4>
                <p class="info-value">Northern Illinois & Southern Wisconsin</p>
                <p class="info-sub">Lake, Cook, McHenry Counties (IL)<br>Walworth, Kenosha, Milwaukee Counties (WI)</p>
              </div>
            </div>
            <div class="info-item">
              <div class="info-icon">🕐</div>
              <div>
                <h4>Hours</h4>
                <p class="info-value">Mon - Fri: 8:00 AM - 5:00 PM</p>
                <p class="info-sub">Saturday: By Appointment</p>
              </div>
            </div>
          </div>

          <div class="card" style="margin-top: 20px;">
            <h4 style="margin-bottom: 16px;">Payment Options</h4>
            <div class="payment-grid">
              <div class="payment-item">💳 Visa</div>
              <div class="payment-item">💳 MasterCard</div>
              <div class="payment-item">💳 Discover</div>
              <div class="payment-item">🅿️ PayPal</div>
            </div>
            <p style="color: var(--text-light); font-size: 0.85rem; margin-top: 12px;">Payment plans available — ask for details.</p>
          </div>
        </div>

        <!-- Form -->
        <div class="contact-form-wrap" data-animate>
          <div class="card">
            <h3 style="margin-bottom: 24px;">No-Hassle Estimate Request</h3>
            <form id="contactForm">
              <div class="form-row">
                <div class="form-group">
                  <label class="form-label" for="fname">First Name *</label>
                  <input type="text" class="form-input" id="fname" name="fname" placeholder="John" required>
                </div>
                <div class="form-group">
                  <label class="form-label" for="lname">Last Name *</label>
                  <input type="text" class="form-input" id="lname" name="lname" placeholder="Smith" required>
                </div>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label class="form-label" for="email">Email *</label>
                  <input type="email" class="form-input" id="email" name="email" placeholder="john@example.com" required>
                </div>
                <div class="form-group">
                  <label class="form-label" for="phone">Phone *</label>
                  <input type="tel" class="form-input" id="phone" name="phone" placeholder="(847) 555-0123" required>
                </div>
              </div>
              <div class="form-group">
                <label class="form-label" for="city">City / Town</label>
                <input type="text" class="form-input" id="city" name="city" placeholder="Libertyville">
              </div>
              <div class="form-group">
                <label class="form-label" for="project">Project Type</label>
                <select class="form-select" id="project" name="project">
                  <option value="">Select a service...</option>
                  <option>Kitchen Remodeling</option>
                  <option>Bathroom Remodeling</option>
                  <option>Basement Finishing</option>
                  <option>Home Addition</option>
                  <option>Deck / Patio</option>
                  <option>Exterior Improvements</option>
                  <option>New Home Construction</option>
                  <option>Home Theater</option>
                  <option>Commercial</option>
                  <option>Handyman / Small Project</option>
                  <option>Design Services</option>
                  <option>Other</option>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label" for="message">Tell us about your project</label>
                <textarea class="form-textarea" id="message" name="message" rows="5" placeholder="Describe your project, timeline, budget, and any specific requirements..."></textarea>
              </div>
              <button type="submit" class="btn btn-primary btn-block btn-lg">Send Request</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<script>
  document.getElementById('contactForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    // In production, this would POST to a backend/Cloudflare Worker
    alert('Thank you for your inquiry! We will get back to you within 24 hours.');
    (e.target as HTMLFormElement).reset();
  });
</script>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 40px;
    align-items: start;
  }
  .info-item {
    display: flex;
    gap: 16px;
    margin-bottom: 28px;
  }
  .info-item:last-child { margin-bottom: 0; }
  .info-icon {
    font-size: 1.3rem;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .info-item h4 {
    font-size: 0.95rem;
    margin-bottom: 4px;
  }
  .info-value {
    color: var(--text);
    font-size: 1rem;
    display: block;
    margin: 0;
    text-decoration: none;
  }
  a.info-value:hover { color: var(--primary); }
  .info-sub {
    color: var(--text-light);
    font-size: 0.85rem;
    margin: 4px 0 0;
  }
  .payment-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }
  .payment-item {
    background: rgba(255,255,255,0.03);
    padding: 10px 14px;
    border-radius: var(--radius);
    font-size: 0.9rem;
    color: var(--text);
    border: 1px solid var(--border);
  }
  .contact-form-wrap h3 { font-size: 1.4rem; }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .form-row { grid-template-columns: 1fr; }
  }
</style>
