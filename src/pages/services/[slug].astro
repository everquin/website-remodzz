---
import Layout from '../../layouts/Layout.astro';
import PortfolioGrid from '../../components/PortfolioGrid.astro';
import { services } from '../../data/services';
import { portfolioItems } from '../../data/portfolio';

export function getStaticPaths() {
  return services.map(service => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;

// Get portfolio items matching this service category
const categoryMap: Record<string, string> = {
  'kitchens': 'kitchens',
  'bathrooms': 'bathrooms',
  'basements': 'basements',
  'additions': 'additions',
  'decks-exteriors': 'decks',
  'new-homes': 'new-homes',
  'commercial': '',
  'handyman': '',
};
const cat = categoryMap[service.slug] || '';
const servicePortfolio = cat ? portfolioItems.filter(p => p.category === cat) : [];
---

<Layout title={service.title} description={service.fullDescription.slice(0, 160)}>

  <section class="page-hero">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a> <span>/</span> <a href="/services">Services</a> <span>/</span> <span>{service.shortTitle}</span>
      </div>
      <h1><span style="font-size: 0.8em; margin-right: 8px;">{service.icon}</span> {service.title}</h1>
      <p>{service.description}</p>
    </div>
  </section>

  <section class="section bg-darker">
    <div class="container">
      <div class="service-detail-grid">
        <div class="service-content" data-animate>
          <h2>Overview</h2>
          <p class="lead">{service.fullDescription}</p>

          {service.features.length > 0 && (
            <div class="features-section">
              <h3>What We Offer</h3>
              <div class="features-grid">
                {service.features.map(f => (
                  <div class="feature-item">
                    <span class="feature-check">✓</span>
                    <span>{f}</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          <div class="service-cta">
            <h3>Interested in {service.shortTitle}?</h3>
            <p>Schedule a free consultation to discuss your project.</p>
            <div style="display: flex; gap: 12px; flex-wrap: wrap;">
              <a href="/contact" class="btn btn-primary">Get Free Estimate</a>
              <a href="tel:8476037614" class="btn btn-ghost">📞 847.603.7614</a>
            </div>
          </div>
        </div>

        {service.images.length > 0 && (
          <div class="service-images" data-animate>
            {service.images.slice(0, 3).map((img, i) => (
              <img
                src={`/images/portfolio/${img}`}
                alt={`${service.title} project ${i + 1}`}
                loading={i === 0 ? 'eager' : 'lazy'}
                class="service-img"
              />
            ))}
          </div>
        )}
      </div>
    </div>
  </section>

  {servicePortfolio.length > 0 && (
    <section class="section bg-dark">
      <div class="container">
        <div class="section-header" data-animate>
          <span class="section-label">Our Work</span>
          <h2 class="section-title">{service.shortTitle} Portfolio</h2>
        </div>
        <PortfolioGrid items={servicePortfolio} showFilters={false} />
        <div class="text-center" style="margin-top: 32px;">
          <a href="/portfolio" class="btn btn-outline">View Full Portfolio</a>
        </div>
      </div>
    </section>
  )}

  <!-- Other Services -->
  <section class="section-sm bg-darker">
    <div class="container">
      <h3 class="text-center" style="margin-bottom: 24px;" data-animate>Other Services</h3>
      <div class="other-services">
        {services.filter(s => s.slug !== service.slug).map(s => (
          <a href={`/services/${s.slug}`} class="other-service-link">
            <span>{s.icon}</span> {s.shortTitle}
          </a>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
  .service-detail-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 60px;
    align-items: start;
  }
  .service-content h2 {
    font-size: 1.6rem;
    margin-bottom: 16px;
  }
  .lead {
    font-size: 1.1rem;
    color: var(--text);
    line-height: 1.8;
    margin-bottom: 36px;
  }
  .features-section {
    margin-bottom: 40px;
  }
  .features-section h3 {
    font-size: 1.2rem;
    margin-bottom: 20px;
  }
  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }
  .feature-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 0.95rem;
    color: var(--text);
    padding: 10px 16px;
    background: rgba(255,255,255,0.02);
    border-radius: var(--radius);
    border: 1px solid var(--border);
  }
  .feature-check {
    color: var(--primary);
    font-weight: 700;
    flex-shrink: 0;
  }
  .service-cta {
    background: var(--card);
    border: 1px solid var(--primary-border);
    border-radius: var(--radius-lg);
    padding: 32px;
  }
  .service-cta h3 {
    font-size: 1.2rem;
    margin-bottom: 8px;
  }
  .service-cta p {
    color: var(--text);
    margin-bottom: 20px;
  }
  .service-images {
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: sticky;
    top: calc(var(--nav-height) + 20px);
  }
  .service-img {
    width: 100%;
    border-radius: var(--radius-lg);
    object-fit: cover;
    max-height: 280px;
  }
  .other-services {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
  }
  .other-service-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 20px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-full);
    color: var(--text);
    font-size: 0.9rem;
    transition: all 0.2s;
  }
  .other-service-link:hover {
    border-color: var(--primary-border);
    color: var(--primary);
    background: var(--primary-glow);
  }
  @media (max-width: 900px) {
    .service-detail-grid { grid-template-columns: 1fr; }
    .service-images {
      position: static;
      flex-direction: row;
      overflow-x: auto;
    }
    .service-img {
      min-width: 280px;
      max-height: 220px;
    }
  }
</style>
