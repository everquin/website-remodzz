---
import Layout from '../../layouts/Layout.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { services, additionalServices } from '../../data/services';
---

<Layout title="Services" description="REMODzz offers comprehensive remodeling, new home construction, and handyman services across Northern Illinois and Southern Wisconsin.">

  <section class="page-hero">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a> <span>/</span> <span>Services</span>
      </div>
      <h1>Our <span class="text-primary">Services</span></h1>
      <p>Comprehensive construction and remodeling for every need and budget.</p>
    </div>
  </section>

  <section class="section bg-darker">
    <div class="container">
      <div class="grid grid-4">
        {services.map(s => (
          <ServiceCard
            title={s.shortTitle}
            icon={s.icon}
            description={s.description}
            href={`/services/${s.slug}`}
          />
        ))}
      </div>

      <div class="section-header" style="margin-top: 80px;" data-animate>
        <span class="section-label">Specialty Services</span>
        <h2 class="section-title">Additional Expertise</h2>
      </div>
      <div class="grid grid-3">
        {additionalServices.map(s => (
          <ServiceCard
            title={s.title}
            icon={s.icon}
            description={s.description}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section bg-dark">
    <div class="container">
      <div class="section-header" data-animate>
        <span class="section-label">How It Works</span>
        <h2 class="section-title">Our Process</h2>
        <p class="section-desc">Every project follows our proven methodology for consistent, exceptional results.</p>
      </div>
      <div class="process-grid">
        <div class="process-step" data-animate>
          <div class="step-num">01</div>
          <h4>Consultation</h4>
          <p>We meet at your home, discuss your vision, assess the space, and outline possibilities. No pressure, no obligation.</p>
        </div>
        <div class="process-step" data-animate>
          <div class="step-num">02</div>
          <h4>Design & Proposal</h4>
          <p>Our in-house team creates detailed designs and renderings. You receive a comprehensive proposal covering 54+ categories.</p>
        </div>
        <div class="process-step" data-animate>
          <div class="step-num">03</div>
          <h4>Build</h4>
          <p>Construction begins with a guaranteed schedule. Regular updates keep you informed, and our team coordinates all trades.</p>
        </div>
        <div class="process-step" data-animate>
          <div class="step-num">04</div>
          <h4>Walkthrough & Warranty</h4>
          <p>Final walkthrough ensures everything meets your expectations. Your 2-year warranty protection begins.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-sm bg-darker">
    <div class="container text-center">
      <h2 data-animate>Ready to Start Your Project?</h2>
      <p style="color: var(--text); max-width: 500px; margin: 12px auto 28px;" data-animate>Contact us for a free, no-hassle estimate.</p>
      <div data-animate>
        <a href="/contact" class="btn btn-primary btn-lg">Get Free Estimate</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .process-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .process-step {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 32px;
    text-align: center;
    position: relative;
  }
  .step-num {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--primary);
    opacity: 0.3;
    margin-bottom: 12px;
  }
  .process-step h4 {
    font-size: 1.1rem;
    margin-bottom: 10px;
  }
  .process-step p {
    font-size: 0.9rem;
    color: var(--text-light);
    margin: 0;
  }
  @media (max-width: 900px) {
    .process-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .process-grid { grid-template-columns: 1fr; }
  }
</style>
